### ========================================
### PARKS
### ========================================

### GET all parks
GET {{baseUrl}}/parks

### GET a single park by ID
GET {{baseUrl}}/parks/{{parkId}}

### CREATE a new park 🔒
POST {{baseUrl}}/parks HTTP/1.1
Content-Type: application/json
Cookie: {{sessionCookie}}

{
  "fullName": "Salt Lake National Park",
  "parkCode": "crla",
  "description": "Salt Lake inspires awe. Deepest lake in the USA.",
  "state": "Utah",
  "region": "Mountain West",
  "latitude": "42.94065854",
  "longitude": "-111.8913889",
  "url": "https://www.nps.gov/crla/index.htm",
  "imageUrl": "https://example.com/crater-lake.jpg",
  "established": "1902",
  "area": "183224"
}

### UPDATE a park 🔒
PUT {{baseUrl}}/parks/{{parkId}} HTTP/1.1
Content-Type: application/json
Cookie: {{sessionCookie}}

{
  "fullName": "Salt Lake Updated Park",
  "parkCode": "crla",
  "description": "Updated description for Salt Lake.",
  "state": "Utah",
  "region": "Mountain West",
  "latitude": "42.940",
  "longitude": "-122.133",
  "url": "https://www.nps.gov/crla/index.htm",
  "imageUrl": "https://example.com/crater-lake.jpg",
  "established": "1902",
  "area": "183224"
}

### DELETE a park 🔒
DELETE {{baseUrl}}/parks/{{parkId}} HTTP/1.1
Cookie: {{sessionCookie}}



### ========================================
### ADVENTURES
### ========================================

### GET all adventures
GET {{baseUrl}}/adventures

### GET adventures filtered by parkId
GET {{baseUrl}}/adventures?parkId={{parkId}}

### GET a single adventure by ID
GET {{baseUrl}}/adventures/{{adventureId}}

### CREATE a new adventure 🔒
POST {{baseUrl}}/adventures HTTP/1.1
Content-Type: application/json
Cookie: {{sessionCookie}}

{
  "parkId": "{{parkId}}",
  "userId": "github12345",
  "title": "Amazing Hike at Crater Lake",
  "description": "Hiked down to the water, it was freezing!",
  "date": "2023-08-15",
  "type": "hike",
  "duration": "3 hours",
  "difficulty": "Moderate",
  "rating": 5
}

### UPDATE an adventure 🔒
PUT {{baseUrl}}/adventures/{{adventureId}} HTTP/1.1
Content-Type: application/json
Cookie: {{sessionCookie}}

{
  "title": "Amazing Hike at Crater Lake",
  "duration": "4 hours",
  "difficulty": "Strenuous",
  "rating": 4
}

### DELETE an adventure 🔒
DELETE {{baseUrl}}/adventures/{{adventureId}} HTTP/1.1
Cookie: {{sessionCookie}}



