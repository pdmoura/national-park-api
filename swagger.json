{
  "swagger": "2.0",
  "info": {
    "title": "National Park Adventures API",
    "description": "API for exploring National Parks. Authentication is handled via GitHub OAuth. Visit /auth/login to authenticate.",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "paths": {
    "/parks/": {
      "get": {
        "tags": [
          "Parks"
        ],
        "description": "Retrieve all parks",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Parks"
        ],
        "description": "Create a new park",
        "parameters": [
          {
            "name": "obj",
            "in": "body",
            "description": "Park object",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "fullName": {
                  "type": "string",
                  "example": "Crater Lake National Park"
                },
                "parkCode": {
                  "type": "string",
                  "example": "crla"
                },
                "description": {
                  "type": "string",
                  "example": "Crater Lake inspires awe. Deepest lake in the USA."
                },
                "state": {
                  "type": "string",
                  "example": "Oregon"
                },
                "region": {
                  "type": "string",
                  "example": "Pacific West"
                },
                "latitude": {
                  "type": "string",
                  "example": "42.94065854"
                },
                "longitude": {
                  "type": "string",
                  "example": "-122.1338414"
                },
                "url": {
                  "type": "string",
                  "example": "https://www.nps.gov/crla/index.htm"
                },
                "imageUrl": {
                  "type": "string",
                  "example": "https://example.com/crater-lake.jpg"
                },
                "established": {
                  "type": "string",
                  "example": "1902"
                },
                "area": {
                  "type": "string",
                  "example": "183224"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
