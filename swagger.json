{
  "swagger": "2.0",
  "info": {
    "title": "National Parks API",
    "description": "API for exploring National Parks",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "tags": [],
  "schemes": [
    "http",
    "https"
  ],
  "securityDefinitions": {
    "Bearer": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Enter your bearer token in the format: Bearer <token>"
    }
  },
  "consumes": [],
  "produces": [],
  "paths": {
    "/parks/": {
      "get": {
        "tags": [
          "Parks"
        ],
        "description": "Retrieve all parks",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Parks"
        ],
        "description": "Create a new park",
        "parameters": [
          {
            "name": "obj",
            "in": "body",
            "description": "Park object",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "fullName": {
                  "type": "string",
                  "example": "Crater Lake National Park"
                },
                "parkCode": {
                  "type": "string",
                  "example": "crla"
                },
                "description": {
                  "type": "string",
                  "example": "Crater Lake inspires awe. Deepest lake in the USA."
                },
                "state": {
                  "type": "string",
                  "example": "Oregon"
                },
                "region": {
                  "type": "string",
                  "example": "Pacific West"
                },
                "latitude": {
                  "type": "string",
                  "example": "42.94065854"
                },
                "longitude": {
                  "type": "string",
                  "example": "-122.1338414"
                },
                "url": {
                  "type": "string",
                  "example": "https://www.nps.gov/crla/index.htm"
                },
                "imageUrl": {
                  "type": "string",
                  "example": "https://example.com/crater-lake.jpg"
                },
                "established": {
                  "type": "string",
                  "example": "1902"
                },
                "area": {
                  "type": "string",
                  "example": "183224"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/parks/{id}": {
      "get": {
        "tags": [
          "Parks"
        ],
        "description": "Retrieve a single park by its ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Parks"
        ],
        "description": "Update a park by its ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "obj",
            "in": "body",
            "description": "Park object",
            "schema": {
              "type": "object",
              "properties": {
                "fullName": {
                  "type": "string",
                  "example": "Crater Lake National Park"
                },
                "parkCode": {
                  "type": "string",
                  "example": "crla"
                },
                "description": {
                  "type": "string",
                  "example": "Crater Lake inspires awe. Deepest lake in the USA."
                },
                "state": {
                  "type": "string",
                  "example": "Idaho"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Parks"
        ],
        "description": "Delete a park by its ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/campgrounds/": {
      "get": {
        "tags": [
          "Campgrounds"
        ],
        "description": "Retrieve all campgrounds, optionally filtered by parkId",
        "parameters": [
          {
            "name": "parkId",
            "in": "query",
            "description": "Optional park ObjectId used to filter campgrounds",
            "required": false,
            "type": "string",
            "example": "64f1234567890abcde123456"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Campgrounds"
        ],
        "description": "Create a new campground. Authentication required.",
        "parameters": [
          {
            "name": "obj",
            "in": "body",
            "description": "Campground object",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "parkId": {
                  "type": "string",
                  "example": "64f1234567890abcde654321"
                },
                "name": {
                  "type": "string",
                  "example": "Rim Village Campground"
                },
                "description": {
                  "type": "string",
                  "example": "Popular lakeside campground with reservable sites."
                },
                "reservationUrl": {
                  "type": "string",
                  "example": "https://example.com/reservations/rim-village"
                },
                "numSites": {
                  "type": "number",
                  "example": 45
                },
                "cost": {
                  "type": "string",
                  "example": "$25 per night"
                },
                "amenities": {
                  "type": "string",
                  "example": "Restrooms, potable water, fire pits"
                },
                "season": {
                  "type": "string",
                  "example": "May through September"
                },
                "latitude": {
                  "type": "string",
                  "example": "42.9446"
                },
                "longitude": {
                  "type": "string",
                  "example": "-122.1090"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/campgrounds/{id}": {
      "get": {
        "tags": [
          "Campgrounds"
        ],
        "description": "Retrieve a single campground by its ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Campground ObjectId",
            "example": "64f1234567890abcde123456"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Campgrounds"
        ],
        "description": "Update an existing campground by its ID. Authentication required.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Campground ObjectId",
            "example": "64f1234567890abcde123456"
          },
          {
            "name": "obj",
            "in": "body",
            "description": "Campground fields to update",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Rim Village Campground"
                },
                "numSites": {
                  "type": "number",
                  "example": 50
                },
                "cost": {
                  "type": "string",
                  "example": "$30 per night"
                },
                "season": {
                  "type": "string",
                  "example": "June through September"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Campgrounds"
        ],
        "description": "Delete a campground by its ID. Authentication required.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Campground ObjectId",
            "example": "64f1234567890abcde123456"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "definitions": {}
}